{
  "expo": {
    "name": "Expo Exp",
    "slug": "expo-experiment-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bfe-app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/bfe-splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.banglafighter.expoexp"
    },
    "android": {
      "package": "com.banglafighter.expoexp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/bfe-app-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
